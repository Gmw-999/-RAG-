# 农业知识 RAG 问答系统 — 环境变量模板
# 复制本文件为 .env 并填入真实密钥，然后运行 ingest.py 和 app.py

# 智谱 Embedding API (https://open.bigmodel.cn)
ZHIPU_EMBEDDING_API_KEY=your_zhipu_api_key_here

# 豆包 Embedding API (已下架，保留备用，可选)
DOUBAO_EMBEDDING_API_KEY=your_doubao_api_key_here

# DeepSeek API (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# BGE-Reranker 模型 (HuggingFace 模型名 或 ModelScope 本地路径)
# 国内用户建议用 ModelScope 下载: pip install modelscope && python -c "from modelscope import snapshot_download; snapshot_download('BAAI/bge-reranker-v2-m3', cache_dir='E:/python/huggingface_models')"
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
